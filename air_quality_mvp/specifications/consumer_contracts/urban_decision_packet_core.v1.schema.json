{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/v1/urban_decision_packet_core",
  "title": "Urban decision packet (domain-neutral core)",
  "description": "Portable shell for grid-based urban decision support: human review, evidence, confidence, and provenance. Domain-specific metrics (air quality, traffic, flood depth, heat index, etc.) live under `prediction`, `provenance`, and `evidence` without being fixed by this schema.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "packet_id",
    "event_id",
    "h3_id",
    "timestamp",
    "confidence_level",
    "actionability_level",
    "why_this_recommendation",
    "risk_of_error",
    "location",
    "summary",
    "prediction",
    "confidence",
    "provenance",
    "data_sources",
    "evidence",
    "likely_contributing_factors",
    "recommended_action",
    "review_guidance",
    "audit_context",
    "provenance_summary",
    "source_reliability_summary"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "event_id": { "type": "string", "minLength": 1 },
    "h3_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "confidence_level": { "type": "string", "minLength": 1 },
    "actionability_level": { "type": "string", "minLength": 1 },
    "why_this_recommendation": { "type": "string" },
    "risk_of_error": {
      "type": "array",
      "items": { "type": "string" }
    },
    "location": {
      "type": "object",
      "additionalProperties": true,
      "required": ["centroid_lat", "centroid_lon", "geometry_geojson"],
      "properties": {
        "centroid_lat": { "type": ["number", "null"] },
        "centroid_lon": { "type": ["number", "null"] },
        "geometry_geojson": {
          "oneOf": [{ "type": "null" }, { "type": "object", "additionalProperties": true }]
        }
      }
    },
    "summary": { "type": "string" },
    "prediction": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "confidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "confidence_score",
        "data_quality_score",
        "driver_confidence",
        "recommendation_allowed",
        "recommendation_block_reason"
      ],
      "properties": {
        "confidence_score": { "type": ["number", "null"] },
        "data_quality_score": { "type": ["number", "null"] },
        "driver_confidence": { "type": "string" },
        "recommendation_allowed": { "type": "boolean" },
        "recommendation_block_reason": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "data_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["source_type", "source_name", "source_mode", "confidence", "notes"],
        "properties": {
          "source_type": { "type": "string" },
          "source_name": { "type": "string" },
          "source_mode": { "type": "string" },
          "confidence": { "type": ["number", "null"] },
          "notes": { "type": "string" }
        }
      }
    },
    "evidence": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "likely_contributing_factors": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["factor", "reason"],
            "additionalProperties": true,
            "properties": {
              "factor": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      ]
    },
    "recommended_action": { "type": "string" },
    "review_guidance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["questions_for_reviewer", "suggested_verification_steps", "when_not_to_act"],
      "properties": {
        "questions_for_reviewer": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggested_verification_steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "when_not_to_act": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "audit_context": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "provenance_summary": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true,
      "description": "Stakeholder-safe coverage summary; v1 AQ pipeline uses percent_cells_*, station counts, etc. Other domains may use different keys (e.g. gauge_count, radar_age_minutes)."
    },
    "source_reliability_summary": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    }
  }
}
