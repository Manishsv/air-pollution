{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/v1/data_audit",
  "$comment": "v1 audit keys are AQ-pipeline specific; add parallel schemas for traffic/flood/heat when those writers exist.",
  "title": "Data audit (v1, AQ-oriented coverage)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "number_of_real_aq_stations",
    "number_of_synthetic_aq_stations",
    "aq_observation_count",
    "aq_completeness_ratio",
    "percent_cells_with_observed_aq",
    "percent_cells_interpolated",
    "percent_cells_synthetic",
    "avg_nearest_station_distance_km",
    "max_nearest_station_distance_km",
    "weather_source_type_counts",
    "fire_source_type_counts",
    "osm_feature_counts",
    "h3_resolution",
    "avg_h3_cell_area_sqkm",
    "warning_flags",
    "recommendation_allowed",
    "recommendation_block_reason",
    "source_reliability_summary",
    "interpolation_quality_score",
    "low_quality_observation_ratio"
  ],
  "properties": {
    "number_of_real_aq_stations": { "type": "integer" },
    "number_of_synthetic_aq_stations": { "type": "integer" },
    "aq_observation_count": { "type": "integer" },
    "aq_completeness_ratio": { "type": "number" },
    "percent_cells_with_observed_aq": { "type": "number" },
    "percent_cells_interpolated": { "type": "number" },
    "percent_cells_synthetic": { "type": "number" },
    "avg_nearest_station_distance_km": { "type": ["number", "null"] },
    "max_nearest_station_distance_km": { "type": ["number", "null"] },
    "weather_source_type_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "fire_source_type_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "osm_feature_counts": {
      "type": "object",
      "additionalProperties": true
    },
    "h3_resolution": { "type": "integer" },
    "avg_h3_cell_area_sqkm": { "type": ["number", "null"] },
    "warning_flags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommendation_allowed": { "type": "boolean" },
    "recommendation_block_reason": { "type": "string" },
    "source_reliability_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["healthy_count", "degraded_count", "suspect_count", "offline_count"],
      "properties": {
        "healthy_count": { "type": "integer" },
        "degraded_count": { "type": "integer" },
        "suspect_count": { "type": "integer" },
        "offline_count": { "type": "integer" }
      }
    },
    "interpolation_quality_score": { "type": "number" },
    "low_quality_observation_ratio": { "type": "number" }
  }
}
