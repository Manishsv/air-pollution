{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/provider/v1/ward_boundary_feed",
  "title": "Provider contract: ward / administrative boundary feed (v1)",
  "description": "Polygon boundaries for wards or other admin units used to aggregate open built-environment signals (OSM, open government data, or licensed extracts). Same feature envelope as building_footprint_feed for reuse.",
  "type": "object",
  "additionalProperties": true,
  "required": ["provider_id", "source_name", "source_type", "features", "license", "source_metadata"],
  "properties": {
    "provider_id": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "license": { "type": "string" },
    "source_metadata": { "type": "object", "additionalProperties": true },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "timestamp",
          "geometry",
          "feature_type",
          "source_record_id",
          "quality_flag",
          "provenance"
        ],
        "properties": {
          "timestamp": { "type": "string", "minLength": 1 },
          "source_record_id": { "type": "string", "minLength": 1 },
          "ward_id": { "type": "string" },
          "area_id": { "type": "string" },
          "geometry": { "type": "object", "additionalProperties": true },
          "feature_type": { "type": "string" },
          "value": { "type": ["number", "string", "null"] },
          "unit": { "type": "string" },
          "quality_flag": { "type": "string" },
          "provenance": { "type": "object", "additionalProperties": true }
        }
      }
    }
  }
}
