{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/provider/v1/drainage_asset_feed",
  "title": "Provider contract: drainage asset feed (v1)",
  "description": "Provider contract for drainage assets (drains/culverts/inlets/outfalls/pumps) used in flood risk decision support.",
  "type": "object",
  "additionalProperties": true,
  "required": ["provider_id", "source_name", "source_type", "records", "license", "source_metadata"],
  "properties": {
    "provider_id": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "license": { "type": "string" },
    "source_metadata": { "type": "object", "additionalProperties": true },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["asset_id", "asset_type", "quality_flag", "provenance"],
        "properties": {
          "asset_id": { "type": "string", "minLength": 1 },
          "entity_id": { "type": "string" },
          "asset_type": { "type": "string", "minLength": 1 },
          "asset_status": { "type": ["string", "null"] },
          "capacity": { "type": ["number", "string", "null"] },
          "capacity_unit": { "type": ["string", "null"] },
          "last_inspected_at": { "type": ["string", "null"] },
          "quality_flag": { "type": "string", "minLength": 1 },
          "provenance": { "type": "object", "additionalProperties": true },
          "geometry": { "type": "object", "additionalProperties": true },
          "latitude": { "type": ["number", "null"] },
          "longitude": { "type": ["number", "null"] },
          "source_metadata": { "type": "object", "additionalProperties": true }
        },
        "anyOf": [{ "required": ["geometry"] }, { "required": ["latitude", "longitude"] }]
      }
    }
  }
}

