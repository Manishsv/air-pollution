{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/provider/v1/flood_incident_feed",
  "title": "Provider contract: flood incident feed (v1)",
  "description": "Provider contract for flood/waterlogging incident records (tickets, dispatch logs, field reports). This is decision support input; it must preserve provenance and quality flags.",
  "type": "object",
  "additionalProperties": true,
  "required": ["provider_id", "source_name", "source_type", "records", "license", "source_metadata"],
  "properties": {
    "provider_id": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "license": { "type": "string" },
    "source_metadata": { "type": "object", "additionalProperties": true },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["incident_time", "incident_type", "quality_flag", "provenance"],
        "properties": {
          "incident_time": { "type": "string", "minLength": 1 },
          "incident_id": { "type": "string" },
          "entity_id": { "type": "string" },
          "incident_type": { "type": "string", "minLength": 1 },
          "severity": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] },
          "reported_by": { "type": ["string", "null"] },
          "quality_flag": { "type": "string", "minLength": 1 },
          "provenance": { "type": "object", "additionalProperties": true },
          "geometry": { "type": "object", "additionalProperties": true },
          "latitude": { "type": ["number", "null"] },
          "longitude": { "type": ["number", "null"] },
          "source_metadata": { "type": "object", "additionalProperties": true }
        },
        "anyOf": [{ "required": ["geometry"] }, { "required": ["latitude", "longitude"] }]
      }
    }
  }
}

