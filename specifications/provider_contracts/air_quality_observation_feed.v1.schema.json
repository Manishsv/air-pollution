{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/provider/v1/air_quality_observation_feed",
  "title": "Provider contract: air quality observation feed (v1)",
  "type": "object",
  "additionalProperties": true,
  "required": ["provider_id", "source_name", "source_type", "records", "license", "source_metadata"],
  "properties": {
    "provider_id": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "license": { "type": "string" },
    "source_metadata": { "type": "object", "additionalProperties": true },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["timestamp", "observed_property", "value", "unit", "quality_flag", "provenance"],
        "properties": {
          "timestamp": { "type": "string", "minLength": 1 },
          "observed_property": { "type": "string", "minLength": 1 },
          "value": { "type": ["number", "string", "null"] },
          "unit": { "type": "string" },
          "quality_flag": { "type": "string" },
          "provenance": { "type": "object", "additionalProperties": true },
          "geometry": { "type": "object", "additionalProperties": true },
          "latitude": { "type": ["number", "null"] },
          "longitude": { "type": ["number", "null"] }
        },
        "anyOf": [
          { "required": ["geometry"] },
          { "required": ["latitude", "longitude"] }
        ]
      }
    }
  }
}

