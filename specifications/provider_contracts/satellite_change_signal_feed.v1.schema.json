{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/provider/v1/satellite_change_signal_feed",
  "title": "Provider contract: satellite / EO change signal feed (v1)",
  "description": "Earth-observation derived change or anomaly signals (e.g. Sentinel-2, Landsat) aligned to wards, H3, or raster cells. Conservative proxies for built-environment review—not permit detection.",
  "type": "object",
  "additionalProperties": true,
  "required": ["provider_id", "source_name", "source_type", "records", "license", "source_metadata"],
  "properties": {
    "provider_id": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "license": { "type": "string" },
    "source_metadata": { "type": "object", "additionalProperties": true },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["observation_time", "observed_property", "value", "unit", "quality_flag", "provenance"],
        "properties": {
          "observation_time": { "type": "string", "minLength": 1 },
          "source_record_id": { "type": "string" },
          "spatial_unit_id": { "type": "string" },
          "spatial_unit_type": { "type": "string" },
          "time_window_start": { "type": "string" },
          "time_window_end": { "type": "string" },
          "entity_id": { "type": "string" },
          "observed_property": { "type": "string", "minLength": 1 },
          "value": { "type": ["number", "string", "null"] },
          "unit": { "type": "string", "minLength": 1 },
          "quality_flag": { "type": "string", "minLength": 1 },
          "provenance": { "type": "object", "additionalProperties": true },
          "geometry": { "type": "object", "additionalProperties": true },
          "latitude": { "type": ["number", "null"] },
          "longitude": { "type": ["number", "null"] },
          "source_metadata": { "type": "object", "additionalProperties": true }
        },
        "anyOf": [{ "required": ["geometry"] }, { "required": ["latitude", "longitude"] }]
      }
    }
  }
}
