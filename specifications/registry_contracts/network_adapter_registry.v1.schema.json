{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/registry/v1/network_adapter_registry",
  "title": "AirOS registry contract: network adapter registry (v1)",
  "description": "Declarative registry describing transport adapter plugins that carry AirOS network contracts (e.g. message_envelope.v1, delivery_receipt.v1) over transports (email/webhook/file drop/event bus). This registry must not contain secrets, API keys, passwords, or mailbox credentials. configuration_ref may point to deployment-local configuration names only (no values).",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_id", "version", "updated_at", "scope", "adapters"],
  "properties": {
    "registry_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1"] },
    "updated_at": { "type": "string", "format": "date-time" },
    "scope": { "type": "string", "enum": ["core_default", "deployment"] },
    "deployment_id": {
      "type": "string",
      "minLength": 1,
      "description": "Optional identifier for the deployment profile (required when scope=deployment)."
    },
    "adapters": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "adapter_id",
          "label",
          "supported_transport",
          "supported_network_contracts",
          "delivery_receipt_support",
          "authentication_method",
          "audit_behavior",
          "retry_behavior",
          "enabled_by_default",
          "status"
        ],
        "properties": {
          "adapter_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "supported_transport": {
            "type": "string",
            "enum": ["email", "api", "webhook", "sftp", "file_drop", "event_bus"]
          },
          "supported_network_contracts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "description": "Manifest artifact keys for supported network contracts (e.g. network_message_envelope_v1)."
          },
          "delivery_receipt_support": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "string",
              "enum": ["delivery_ack", "delivery_nack", "processing_ack", "processing_nack", "status_update"]
            }
          },
          "authentication_method": {
            "type": "string",
            "minLength": 1,
            "description": "High-level auth approach (no credentials inline)."
          },
          "audit_behavior": {
            "type": "string",
            "minLength": 1,
            "description": "How adapter emits or links audit metadata (message_id, transport_message_ref)."
          },
          "retry_behavior": {
            "type": "string",
            "minLength": 1,
            "description": "Backoff/idempotency posture; dead-letter handling; retry policy knobs."
          },
          "configuration_ref": {
            "type": "string",
            "minLength": 1,
            "description": "Reference to deployment-local configuration/secret bundle name (no values)."
          },
          "operational_owner": {
            "type": "string",
            "minLength": 1,
            "description": "Owning role/team label (no personal PII in public repos)."
          },
          "notes": { "type": "string" },
          "enabled_by_default": { "type": "boolean" },
          "status": {
            "type": "string",
            "enum": ["reference", "experimental", "deployment_private", "deprecated"]
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "scope": { "const": "deployment" } } },
      "then": { "required": ["deployment_id"] }
    }
  ]
}

