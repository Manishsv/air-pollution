{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/registry/v1/program_spec_registry",
  "title": "AirOS registry contract: program specification catalog (v1, Phase 1)",
  "description": "Catalog of published program bundles. Phase 1 references submission + review consumer contracts only (no separate provider evidence feeds).",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_id", "version", "updated_at", "programs"],
  "properties": {
    "registry_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1"] },
    "updated_at": { "type": "string", "format": "date-time" },
    "issuer_node_id": { "type": "string" },
    "programs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "program_id",
          "version",
          "status",
          "bundle_relative_path",
          "required_submission_contract",
          "review_output_contract"
        ],
        "properties": {
          "program_id": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["draft_demo", "published", "deprecated"]
          },
          "bundle_relative_path": {
            "type": "string",
            "minLength": 1,
            "description": "Path relative to specifications/, e.g. program_specs/stormwater_resilience_grant_2026/"
          },
          "required_submission_contract": {
            "type": "string",
            "minLength": 1,
            "description": "Manifest artifact key for city submission consumer contract (e.g. consumer_city_program_submission)."
          },
          "review_output_contract": {
            "type": "string",
            "minLength": 1,
            "description": "Manifest artifact key for state review packet (e.g. consumer_fund_release_review_packet)."
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
