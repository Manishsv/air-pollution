{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/v1/decision_packet.profile.air_quality",
  "title": "Decision packet — air quality (PM2.5) profile, v1",
  "description": "Strict contract for the current air-quality MVP: PM2.5 forecasts, India AQI bands, AQ sensors, and auxiliary weather/fire provenance. Other domains (traffic, flood, heat) should add sibling profiles, e.g. `decision_packet.profile.flood.v1.schema.json`, while conforming to `urban_decision_packet_core.v1.schema.json`.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "packet_id",
    "event_id",
    "h3_id",
    "timestamp",
    "confidence_level",
    "actionability_level",
    "why_this_recommendation",
    "risk_of_error",
    "location",
    "summary",
    "prediction",
    "confidence",
    "provenance",
    "data_sources",
    "evidence",
    "likely_contributing_factors",
    "recommended_action",
    "review_guidance",
    "audit_context",
    "provenance_summary",
    "source_reliability_summary"
  ],
  "properties": {
    "packet_id": { "type": "string", "pattern": "^pkt_[0-9a-f]{16}$" },
    "event_id": { "type": "string", "pattern": "^evt_[0-9a-f]{16}$" },
    "h3_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "confidence_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "actionability_level": { "type": "string", "minLength": 1 },
    "why_this_recommendation": { "type": "string" },
    "risk_of_error": {
      "type": "array",
      "items": { "type": "string" }
    },
    "location": {
      "type": "object",
      "additionalProperties": true,
      "required": ["centroid_lat", "centroid_lon", "geometry_geojson"],
      "properties": {
        "centroid_lat": { "type": ["number", "null"] },
        "centroid_lon": { "type": ["number", "null"] },
        "geometry_geojson": {
          "oneOf": [{ "type": "null" }, { "type": "object", "additionalProperties": true }]
        }
      }
    },
    "summary": { "type": "string" },
    "prediction": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "current_pm25",
        "forecast_pm25_mean",
        "forecast_pm25_p10",
        "forecast_pm25_p50",
        "forecast_pm25_p90",
        "forecast_pm25_std",
        "uncertainty_band",
        "pm25_category_india"
      ],
      "properties": {
        "current_pm25": { "type": ["number", "null"] },
        "forecast_pm25_mean": { "type": ["number", "null"] },
        "forecast_pm25_p10": { "type": ["number", "null"] },
        "forecast_pm25_p50": { "type": ["number", "null"] },
        "forecast_pm25_p90": { "type": ["number", "null"] },
        "forecast_pm25_std": { "type": ["number", "null"] },
        "uncertainty_band": { "type": ["number", "null"] },
        "pm25_category_india": { "type": "string" }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "confidence_score",
        "data_quality_score",
        "driver_confidence",
        "recommendation_allowed",
        "recommendation_block_reason"
      ],
      "properties": {
        "confidence_score": { "type": ["number", "null"] },
        "data_quality_score": { "type": ["number", "null"] },
        "driver_confidence": { "type": "string" },
        "recommendation_allowed": { "type": "boolean" },
        "recommendation_block_reason": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "aq_source_type",
        "weather_source_type",
        "fire_source_type",
        "interpolation_method",
        "nearest_station_distance_km",
        "station_count_used",
        "warning_flags",
        "aq_source_reliability_min",
        "aq_source_reliability_avg"
      ],
      "properties": {
        "aq_source_type": { "type": "string" },
        "weather_source_type": { "type": "string" },
        "fire_source_type": { "type": "string" },
        "interpolation_method": { "type": "string" },
        "nearest_station_distance_km": { "type": ["number", "null"] },
        "station_count_used": { "type": "integer" },
        "warning_flags": { "type": "string" },
        "aq_source_reliability_min": { "type": ["number", "null"] },
        "aq_source_reliability_avg": { "type": ["number", "null"] }
      }
    },
    "data_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["source_type", "source_name", "source_mode", "confidence", "notes"],
        "properties": {
          "source_type": { "type": "string" },
          "source_name": { "type": "string" },
          "source_mode": { "type": "string" },
          "confidence": { "type": ["number", "null"] },
          "notes": { "type": "string" }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "observed_pm25_records",
        "observed_pm25_note",
        "nearby_station_records",
        "nearby_station_note",
        "weather_records",
        "static_features",
        "dynamic_features",
        "top_features_used"
      ],
      "properties": {
        "observed_pm25_records": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "observed_pm25_note": { "type": "string" },
        "nearby_station_records": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "nearby_station_note": { "type": "string" },
        "weather_records": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "static_features": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "dynamic_features": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "top_features_used": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "likely_contributing_factors": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["factor", "reason"],
            "additionalProperties": true,
            "properties": {
              "factor": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      ]
    },
    "recommended_action": { "type": "string" },
    "review_guidance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["questions_for_reviewer", "suggested_verification_steps", "when_not_to_act"],
      "properties": {
        "questions_for_reviewer": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggested_verification_steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "when_not_to_act": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "audit_context": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "number_of_real_aq_stations",
        "percent_cells_interpolated",
        "percent_cells_synthetic",
        "avg_nearest_station_distance_km",
        "spatial_validation_rmse",
        "model_vs_persistence_summary"
      ],
      "properties": {
        "number_of_real_aq_stations": { "type": "integer" },
        "percent_cells_interpolated": { "type": "number" },
        "percent_cells_synthetic": { "type": "number" },
        "avg_nearest_station_distance_km": { "type": "number" },
        "spatial_validation_rmse": { "type": ["number", "null"] },
        "model_vs_persistence_summary": { "type": "string" }
      }
    },
    "provenance_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "percent_cells_interpolated",
        "percent_cells_synthetic",
        "percent_low_confidence",
        "number_of_real_aq_stations",
        "avg_nearest_station_distance_km",
        "recommendation_allowed",
        "recommendation_block_reason"
      ]
    },
    "source_reliability_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "aq_sensor_status_counts",
        "weather_source_status_counts",
        "low_reliability_sources_nearby",
        "reliability_warnings"
      ],
      "properties": {
        "aq_sensor_status_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "weather_source_status_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "low_reliability_sources_nearby": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "reliability_warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
