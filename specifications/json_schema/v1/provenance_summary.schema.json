{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/v1/provenance_summary",
  "title": "Provenance summary (v1, AQ-oriented keys)",
  "description": "Stakeholder-facing coverage summary. v1 field names reflect the first pipeline (H3 cells, AQ stations). Other domains may reuse values semantically while planning a neutral key set in v2.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "percent_cells_interpolated",
    "percent_cells_synthetic",
    "percent_low_confidence",
    "number_of_real_aq_stations",
    "avg_nearest_station_distance_km",
    "recommendation_allowed",
    "recommendation_block_reason"
  ],
  "properties": {
    "percent_cells_interpolated": { "type": "number" },
    "percent_cells_synthetic": { "type": "number" },
    "percent_low_confidence": { "type": ["number", "null"] },
    "number_of_real_aq_stations": { "type": "integer" },
    "avg_nearest_station_distance_km": { "type": ["number", "null"] },
    "recommendation_allowed": { "type": "boolean" },
    "recommendation_block_reason": { "type": "string" }
  }
}
