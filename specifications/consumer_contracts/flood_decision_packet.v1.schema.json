{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/consumer/v1/flood_decision_packet",
  "title": "Consumer contract: flood decision packet (v1)",
  "description": "Decision packet profile for the flood_risk domain. Decision support only; must include safety gates, blocked uses, and field verification requirements.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "packet_id",
    "domain_id",
    "timestamp",
    "risk_assessment",
    "evidence",
    "provenance",
    "confidence",
    "uncertainty",
    "recommended_action",
    "review_guidance",
    "safety_gates",
    "blocked_uses",
    "field_verification_required"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "domain_id": { "const": "flood_risk" },
    "timestamp": { "type": "string", "minLength": 1 },
    "area_id": { "type": "string" },
    "h3_id": { "type": "string" },
    "risk_assessment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["risk_level", "time_window"],
      "properties": {
        "risk_level": { "type": "string", "minLength": 1 },
        "time_window": { "type": "string", "minLength": 1 },
        "primary_driver": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["inputs"],
      "properties": {
        "inputs": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "notes": { "type": "string" }
      }
    },
    "provenance": { "type": "object", "minProperties": 1, "additionalProperties": true },
    "confidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["confidence_score", "recommendation_allowed"],
      "properties": {
        "confidence_score": { "type": ["number", "null"] },
        "recommendation_allowed": { "type": "boolean" },
        "recommendation_block_reason": { "type": "string" }
      }
    },
    "uncertainty": { "type": "object", "additionalProperties": true },
    "recommended_action": { "type": "string" },
    "review_guidance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["review_prompts", "when_not_to_act"],
      "properties": {
        "review_prompts": { "type": "array", "items": { "type": "string" } },
        "when_not_to_act": { "type": "array", "items": { "type": "string" } }
      }
    },
    "safety_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["gate_id", "status"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "message": { "type": "string" }
        }
      }
    },
    "blocked_uses": { "type": "array", "items": { "type": "string" } },
    "field_verification_required": { "type": "boolean" },
    "field_verification_task": { "type": "object", "additionalProperties": true }
  },
  "anyOf": [{ "required": ["area_id"] }, { "required": ["h3_id"] }]
}

