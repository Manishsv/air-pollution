{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/consumer/v1/fund_release_review_packet",
  "title": "Consumer contract: fund release review packet (v1, Phase 1)",
  "description": "Phase 1: state structured review of a city submission (progress + financial self-report). No auto fund release; authorized humans and finance processes remain authoritative. Echoes reference_data_versions from the submission for audit alignment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "state_node_id",
    "city_id",
    "program_id",
    "program_spec_version",
    "reporting_period",
    "submission_id",
    "generated_at",
    "review_status",
    "fund_release_review_status",
    "progress_assessment",
    "financial_assessment",
    "flags",
    "required_human_approvals",
    "confidence",
    "blocked_uses",
    "review_notes",
    "provenance",
    "reference_data_versions"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "state_node_id": { "type": "string", "minLength": 1 },
    "city_id": { "type": "string", "minLength": 1 },
    "program_id": { "type": "string", "minLength": 1 },
    "program_spec_version": { "type": "string", "minLength": 1 },
    "reporting_period": { "type": "string", "minLength": 1 },
    "submission_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "review_status": {
      "type": "string",
      "enum": ["review_ready", "clarification_required", "human_review_required", "rejected"]
    },
    "fund_release_review_status": {
      "type": "string",
      "enum": ["not_reviewed", "ready_for_authorized_review", "clarification_needed", "not_ready"]
    },
    "progress_assessment": { "type": "object", "additionalProperties": true },
    "financial_assessment": { "type": "object", "additionalProperties": true },
    "flags": { "type": "array", "items": { "type": "string" } },
    "required_human_approvals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "blocked_uses": {
      "type": "array",
      "minItems": 4,
      "items": { "type": "string", "minLength": 1 }
    },
    "review_notes": { "type": "string" },
    "provenance": { "type": "object", "additionalProperties": true },
    "reference_data_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["administrative_units", "program_catalog", "reporting_periods"],
      "properties": {
        "administrative_units": { "type": "string", "minLength": 1 },
        "program_catalog": { "type": "string", "minLength": 1 },
        "reporting_periods": { "type": "string", "minLength": 1 }
      }
    }
  }
}
