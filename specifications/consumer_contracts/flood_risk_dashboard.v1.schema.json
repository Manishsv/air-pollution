{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/consumer/v1/flood_risk_dashboard",
  "title": "Consumer contract: flood risk dashboard payload (v1)",
  "description": "Dashboard payload contract for flood risk situational awareness and review queue. Must include provenance/confidence and visible warnings for low-confidence/synthetic inputs.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "generated_at",
    "risk_summary",
    "map_layers",
    "risk_areas",
    "active_warnings",
    "data_quality_summary",
    "recommended_review_queue",
    "provenance_summary"
  ],
  "properties": {
    "city_id": { "type": "string" },
    "area_id": { "type": "string" },
    "generated_at": { "type": "string", "minLength": 1 },
    "risk_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["overall_risk_level", "time_window"],
      "properties": {
        "overall_risk_level": { "type": "string", "minLength": 1 },
        "time_window": { "type": "string", "minLength": 1 },
        "headline": { "type": "string" }
      }
    },
    "map_layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["layer_id", "layer_type", "title"],
        "properties": {
          "layer_id": { "type": "string", "minLength": 1 },
          "layer_type": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "source_packet_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "risk_cells": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["h3_id", "risk_level", "confidence_score"],
        "properties": {
          "h3_id": { "type": "string", "minLength": 1 },
          "risk_level": { "type": "string", "minLength": 1 },
          "confidence_score": { "type": ["number", "null"] },
          "uncertainty": { "type": "object", "additionalProperties": true },
          "geometry": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "risk_areas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["area_id", "risk_level", "confidence_score"],
        "properties": {
          "area_id": { "type": "string", "minLength": 1 },
          "risk_level": { "type": "string", "minLength": 1 },
          "confidence_score": { "type": ["number", "null"] },
          "uncertainty": { "type": "object", "additionalProperties": true },
          "geometry_geojson": { "oneOf": [{ "type": "null" }, { "type": "object", "additionalProperties": true }] }
        }
      }
    },
    "active_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["warning_id", "severity", "message"],
        "properties": {
          "warning_id": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "data_quality_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["synthetic_data_used", "confidence_note"],
      "properties": {
        "synthetic_data_used": { "type": "boolean" },
        "confidence_note": { "type": "string" },
        "source_reliability_overview": { "type": "object", "additionalProperties": true }
      }
    },
    "recommended_review_queue": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["packet_id", "priority", "reason"],
        "properties": {
          "packet_id": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "provenance_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["sources", "synthetic_used"],
      "properties": {
        "sources": { "type": "array", "items": { "type": "string" } },
        "synthetic_used": { "type": "boolean" }
      }
    }
  },
  "anyOf": [{ "required": ["city_id"] }, { "required": ["area_id"] }]
}

