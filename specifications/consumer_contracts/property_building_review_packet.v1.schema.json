{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/consumer/v1/property_building_review_packet",
  "title": "Consumer contract: built-environment review packet (domain property_buildings, v1)",
  "description": "Review packet for open-signal built-environment change triage. Phase 1 packets may be produced without municipal registry, permit, or tax feeds; optional later-stage identifiers (e.g. property_id) appear only when authorized integrations exist. Field verification and human judgment required. Must not assert property tax status, permit compliance, ownership, or enforcement outcomes.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "packet_id",
    "domain_id",
    "timestamp",
    "issue_type",
    "evidence",
    "provenance",
    "confidence",
    "recommended_review_action",
    "review_guidance",
    "safety_gates",
    "blocked_uses",
    "field_verification_required"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 1 },
    "domain_id": { "const": "property_buildings" },
    "timestamp": { "type": "string", "minLength": 1 },

    "area_id": { "type": "string" },
    "property_id": { "type": "string" },
    "parcel_id": { "type": "string" },
    "building_id": { "type": "string" },

    "issue_type": {
      "type": "string",
      "minLength": 1,
      "description": "e.g. built_up_change_candidate, new_construction_area_candidate, eo_change_signal_review, high_change_ward, footprint_growth_review, data_readiness_review — not under_assessment or permit_guilt labels"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["inputs"],
      "properties": {
        "inputs": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "notes": { "type": "string" }
      }
    },
    "provenance": { "type": "object", "minProperties": 1, "additionalProperties": true },
    "confidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["confidence_score", "recommendation_allowed"],
      "properties": {
        "confidence_score": { "type": ["number", "null"] },
        "recommendation_allowed": { "type": "boolean" },
        "recommendation_block_reason": { "type": "string" }
      }
    },
    "recommended_review_action": { "type": "string", "minLength": 1 },
    "review_guidance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["review_prompts", "when_not_to_act"],
      "properties": {
        "review_prompts": { "type": "array", "items": { "type": "string" } },
        "when_not_to_act": { "type": "array", "items": { "type": "string" } }
      }
    },
    "safety_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["gate_id", "status"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "message": { "type": "string" }
        }
      }
    },
    "blocked_uses": { "type": "array", "items": { "type": "string" } },
    "field_verification_required": { "type": "boolean" },
    "field_verification_task": { "type": "object", "additionalProperties": true }
  },
  "anyOf": [
    { "required": ["area_id"] },
    { "required": ["property_id"] },
    { "required": ["parcel_id"] },
    { "required": ["building_id"] }
  ]
}

