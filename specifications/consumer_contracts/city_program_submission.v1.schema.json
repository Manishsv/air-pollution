{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/consumer/v1/city_program_submission",
  "title": "Consumer contract: city program submission (v1, Phase 1)",
  "description": "Phase 1: self-reported program progress and financial utilization for a reporting period. Review-only; not a fund release instruction. No photo/field/geo evidence in this contract. city_id, program_id, and reporting_period are expected to align with state-published reference catalogs; reference_data_versions records which catalog versions the submitter used.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "submission_id",
    "city_id",
    "program_id",
    "program_spec_version",
    "reporting_period",
    "submitted_at",
    "reporting_officer_role",
    "program_progress",
    "financial_progress",
    "self_reported_issues",
    "provenance_summary",
    "warnings",
    "blocked_uses",
    "human_review_required",
    "reference_data_versions"
  ],
  "properties": {
    "submission_id": { "type": "string", "minLength": 1 },
    "city_id": { "type": "string", "minLength": 1 },
    "program_id": { "type": "string", "minLength": 1 },
    "program_spec_version": { "type": "string", "minLength": 1 },
    "reporting_period": { "type": "string", "minLength": 1 },
    "submitted_at": { "type": "string", "format": "date-time" },
    "reporting_officer_role": { "type": "string", "minLength": 1 },
    "program_progress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projects_total",
        "projects_completed",
        "projects_in_progress",
        "projects_delayed",
        "overall_progress_pct"
      ],
      "properties": {
        "projects_total": { "type": "integer", "minimum": 0 },
        "projects_completed": { "type": "integer", "minimum": 0 },
        "projects_in_progress": { "type": "integer", "minimum": 0 },
        "projects_delayed": { "type": "integer", "minimum": 0 },
        "overall_progress_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "financial_progress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount_approved", "amount_released", "amount_spent", "utilization_pct"],
      "properties": {
        "amount_approved": { "type": "number", "minimum": 0 },
        "amount_released": { "type": "number", "minimum": 0 },
        "amount_spent": { "type": "number", "minimum": 0 },
        "utilization_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "self_reported_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["code", "description"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "provenance_summary": { "type": "object", "additionalProperties": true },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "blocked_uses": {
      "type": "array",
      "minItems": 4,
      "items": { "type": "string", "minLength": 1 }
    },
    "human_review_required": { "const": true },
    "reference_data_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["administrative_units", "program_catalog", "reporting_periods"],
      "properties": {
        "administrative_units": { "type": "string", "minLength": 1 },
        "program_catalog": { "type": "string", "minLength": 1 },
        "reporting_periods": { "type": "string", "minLength": 1 }
      },
      "description": "Version strings (e.g. v1) for each required reference catalog declared by the program spec."
    }
  }
}
