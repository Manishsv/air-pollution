{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/consumer/v1/field_verification_task",
  "title": "Consumer contract: field verification task (v1)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_id",
    "source_packet_id",
    "domain_id",
    "location",
    "assigned_role",
    "verification_questions",
    "evidence_to_collect",
    "priority",
    "status",
    "created_at"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "source_packet_id": { "type": "string", "minLength": 1 },
    "domain_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "priority": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "assigned_role": { "type": "string", "minLength": 1 },
    "location": {
      "type": "object",
      "additionalProperties": true,
      "required": ["centroid_lat", "centroid_lon"],
      "properties": {
        "centroid_lat": { "type": ["number", "null"] },
        "centroid_lon": { "type": ["number", "null"] },
        "geometry_geojson": { "oneOf": [{ "type": "null" }, { "type": "object", "additionalProperties": true }] }
      }
    },
    "verification_questions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "evidence_to_collect": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  }
}

