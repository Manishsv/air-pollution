{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/consumer/v1/air_quality_dashboard",
  "title": "Consumer contract: air quality dashboard payload (v1)",
  "description": "Dashboard payload for air quality situational awareness. Includes PM2.5-based India AQI, H3 risk grid, and sensor provenance.",
  "type": "object",
  "additionalProperties": true,
  "required": ["generated_at", "risk_summary", "map_layers", "risk_areas", "active_warnings", "data_quality_summary", "recommended_review_queue", "provenance_summary"],
  "properties": {
    "city_id": { "type": "string" },
    "generated_at": { "type": "string", "minLength": 1 },
    "risk_summary": {
      "type": "object", "additionalProperties": true,
      "required": ["overall_aqi_category", "time_window"],
      "properties": {
        "overall_aqi_category": { "type": "string", "minLength": 1 },
        "time_window": { "type": "string", "minLength": 1 },
        "headline": { "type": "string" }
      }
    },
    "map_layers": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": true,
        "required": ["layer_id", "layer_type", "title"]
      }
    },
    "risk_cells": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": true,
        "required": ["h3_id", "aqi_category", "confidence_score"]
      }
    },
    "risk_areas": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": true,
        "required": ["area_id", "aqi_category", "confidence_score"]
      }
    },
    "active_warnings": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": true,
        "required": ["warning_id", "severity", "message"]
      }
    },
    "data_quality_summary": {
      "type": "object", "additionalProperties": true,
      "required": ["synthetic_data_used", "confidence_note"],
      "properties": {
        "synthetic_data_used": { "type": "boolean" },
        "confidence_note": { "type": "string" }
      }
    },
    "recommended_review_queue": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": true,
        "required": ["packet_id", "priority", "reason"]
      }
    },
    "provenance_summary": {
      "type": "object", "additionalProperties": true,
      "required": ["sources", "synthetic_used"],
      "properties": {
        "sources": { "type": "array", "items": { "type": "string" } },
        "synthetic_used": { "type": "boolean" }
      }
    }
  }
}
