{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urban-platform.local/spec/platform_object/v1/reference_catalog",
  "title": "Platform object: Reference catalog (v1)",
  "description": "Declarative shared reference data (codes, labels, validity windows) for aligned state–city reporting. No distribution, signing, or cache semantics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "catalog_id",
    "version",
    "publisher_node_id",
    "catalog_type",
    "status",
    "valid_from",
    "expires_at",
    "entries",
    "provenance"
  ],
  "properties": {
    "catalog_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "publisher_node_id": { "type": "string", "minLength": 1 },
    "catalog_type": {
      "type": "string",
      "enum": ["administrative_units", "program_catalog", "reporting_periods", "other"]
    },
    "status": {
      "type": "string",
      "enum": ["draft_demo", "active", "deprecated", "retired"]
    },
    "valid_from": { "type": "string", "format": "date" },
    "expires_at": { "type": "string", "format": "date" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "label", "status", "valid_from", "valid_until"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["active", "inactive", "deprecated"]
          },
          "valid_from": { "type": "string", "format": "date" },
          "valid_until": { "type": "string", "format": "date" },
          "parent_code": { "type": "string", "minLength": 1 },
          "metadata": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "provenance": { "type": "object", "additionalProperties": true }
  }
}
