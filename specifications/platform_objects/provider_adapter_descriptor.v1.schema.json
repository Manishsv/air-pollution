{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airos.local/specifications/platform_objects/provider_adapter_descriptor.v1.schema.json",
  "title": "Provider Adapter Descriptor (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adapter_id",
    "name",
    "version",
    "status",
    "adapter_type",
    "source_system_type",
    "description",
    "output_contracts",
    "configuration",
    "provenance",
    "safety"
  ],
  "properties": {
    "adapter_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Stable adapter identifier (snake_case), e.g. openaq_air_quality_adapter."
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft_demo", "pilot", "beta", "production"]
    },
    "adapter_type": {
      "type": "string",
      "enum": [
        "api_connector",
        "file_connector",
        "sensor_connector",
        "database_connector",
        "stream_connector",
        "manual_upload",
        "other"
      ]
    },
    "source_system_type": {
      "type": "string",
      "minLength": 1,
      "description": "E.g. air_quality_feed, weather_feed, geospatial_feed, municipal_erp, complaint_system, property_registry."
    },
    "description": { "type": "string", "minLength": 1 },
    "output_contracts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "description": "Manifest artifact keys this adapter can emit. May be empty in draft descriptors with explicit notes."
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_settings", "optional_settings", "secrets_required", "notes"],
      "properties": {
        "required_settings": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "optional_settings": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "secrets_required": { "type": "boolean" },
        "notes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_module", "current_function_examples"],
      "properties": {
        "current_module": {
          "type": "string",
          "minLength": 1,
          "description": "Documentation only; must not be used for dynamic imports."
        },
        "current_function_examples": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Documentation only; must not be executed or imported from this descriptor."
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "produces_final_decisions",
        "records_include_provenance",
        "records_include_quality_flags",
        "notes"
      ],
      "properties": {
        "produces_final_decisions": {
          "type": "boolean",
          "enum": [false],
          "description": "Must be false; adapters never produce final decisions."
        },
        "records_include_provenance": { "type": "boolean" },
        "records_include_quality_flags": { "type": "boolean" },
        "notes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publisher", "source"],
      "properties": {
        "publisher": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "updated_at": {
          "type": "string",
          "minLength": 1,
          "description": "ISO 8601 date/time string (not strictly validated)."
        }
      }
    }
  }
}

