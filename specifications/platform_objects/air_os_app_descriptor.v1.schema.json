{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airos.local/specifications/platform_objects/air_os_app_descriptor.v1.schema.json",
  "title": "AirOS App Descriptor (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "app_id",
    "name",
    "version",
    "status",
    "domain_id",
    "description",
    "app_type",
    "input_contracts",
    "output_contracts",
    "decision_logic",
    "deployment_examples",
    "dashboard",
    "safety",
    "provenance"
  ],
  "properties": {
    "app_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Stable app identifier (snake_case), e.g. program_reporting_review."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable version tag, e.g. v1."
    },
    "status": {
      "type": "string",
      "enum": ["draft_demo", "pilot", "beta", "production"]
    },
    "domain_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Domain identifier, e.g. program_reporting, flood_risk."
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "app_type": {
      "type": "string",
      "enum": ["review_support", "monitoring", "forecasting", "simulation", "reporting", "other"]
    },
    "input_contracts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "description": "Array of manifest artifact keys that this app expects as inputs."
    },
    "output_contracts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "description": "Array of manifest artifact keys that this app may produce as outputs."
    },
    "decision_logic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["builder_ids", "description", "execution_model"],
      "properties": {
        "builder_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 },
          "description": "Allowlisted safe builder registry IDs."
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "execution_model": {
          "type": "string",
          "enum": ["allowlisted_python_builder", "external_service_future"]
        }
      }
    },
    "deployment_examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["deployment_id", "path"],
        "properties": {
          "deployment_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Repo-relative path to a deployment example folder."
          }
        }
      }
    },
    "dashboard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["panels", "supports_file_mode", "supports_api_mode"],
      "properties": {
        "panels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "supports_file_mode": { "type": "boolean" },
        "supports_api_mode": { "type": "boolean" }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_support_only", "human_review_required", "blocked_uses", "notes"],
      "properties": {
        "review_support_only": { "type": "boolean" },
        "human_review_required": { "type": "boolean" },
        "blocked_uses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publisher", "updated_at", "source"],
      "properties": {
        "publisher": { "type": "string", "minLength": 1 },
        "updated_at": {
          "type": "string",
          "minLength": 1,
          "description": "ISO 8601 date/time string (not strictly validated)."
        },
        "source": { "type": "string", "minLength": 1 }
      }
    }
  }
}

