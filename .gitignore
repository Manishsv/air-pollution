.DS_Store
__pycache__/
*.pyc
.venv/
.env

# Local caches / outputs
cache/
data/raw/
data/processed/
data/outputs/
data/store/

# Runtime databases (generated by ingestor / feature store — not source files)
data/h3/
data/*.duckdb
data/*.duckdb.wal

# Local tooling / AI agent runtime state
.claire/
.agent-loop/*.md
.agent-loop/*.patch
.agent-loop/*.txt
.agent-loop/*.json
.agent-loop/state.json

# Local tooling / packaging / evidence artifacts
.airos/
dist/
backups/
*.zip
*.redacted.zip

# Notebook checkpoints
.ipynb_checkpoints/

tools/ai_dev_supervisor/reports/*.json
tools/ai_dev_supervisor/reports/*.md
!tools/ai_dev_supervisor/reports/.gitkeep

# Local edge/runtime feeds
data/edge/*.jsonl

# Local CI/virtualenv artifacts
.ci_venv/

# Node artifacts (dev only)
node_modules/
.claude/

# agentic framework — commit config and tasks; ignore runtime state
.agent-loop/state/reviews.yaml
.agent-loop/state/escalations.yaml
.agent-loop/state/decisions.yaml
