# Optional: NASA FIRMS API key for fire events
FIRMS_API_KEY=

# Optional: OpenAQ v3 API key (recommended; v2 is retired and returns 410)
OPENAQ_API_KEY=

# ── AIR Climate Suite data sources ───────────────────────────────────────

# CPCB real-time AQI (data.gov.in) — enables real Indian station data for air quality
# Without this, air panel falls back to OpenMeteo (coarser grid, synthetic)
CPCB_API_KEY=

# Copernicus Data Space Ecosystem — enables Sentinel-2 green cover, water quality,
# construction, and waste signals. Get credentials at dataspace.copernicus.eu
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# Google Earth Engine — still used for MODIS LST (heat) and GPM IMERG (flood)
# until those domains are migrated to CDSE. Leave blank to skip.
GEE_PROJECT=

# GEE service account credentials (required when interactive OAuth is blocked)
GEE_SERVICE_ACCOUNT=airclimate-gee@your-project.iam.gserviceaccount.com
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gee-key.json

# ── AIR Climate Suite notifications ──────────────────────────────────────────

# Backend: log (default) | smtp | digit3
NOTIFICATION_BACKEND=log

# Recipients — comma-separated email addresses (city-specific key overrides global)
ALERT_RECIPIENTS=officer@city.gov.in
ALERT_RECIPIENTS_BANGALORE=bangalore-officer@bbmp.gov.in

# SMTP backend (set NOTIFICATION_BACKEND=smtp to use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@airclimate.in

# DIGIT3 Notification backend (set NOTIFICATION_BACKEND=digit3 when DIGIT3 is deployed)
DIGIT3_NOTIFICATION_URL=http://digit3-host/notification/v1/send
DIGIT3_AUTH_TOKEN=

# ── AIR Climate Suite Decision Object transport ───────────────────────────────

# POST Decision Objects to AIRNet events endpoint (when AIRNet is deployed)
# Without this, decisions are appended to DECISION_LOG_PATH (local fallback)
AIRNET_EVENTS_URL=

# Local fallback log for Decision Objects (default: data/events/decisions.jsonl)
DECISION_LOG_PATH=data/events/decisions.jsonl

# ── Batch scheduler ──────────────────────────────────────────────────────────
# Run with: python main.py --step scheduler
#
# Which cities to include (default: all configured cities)
SCHEDULER_CITIES=bangalore,hyderabad,mumbai,delhi,chennai,pune
#
# 'weather' domain pulls wind speed/direction, humidity, pressure from Open-Meteo (free, no key needed)
# and broadcasts the values to every H3 cell — giving the AI agent cross-domain causal context.
#
# Which domains to include (default: all)
# SCHEDULER_DOMAINS=air,fire,heat,flood,water,waste,construction,green,noise,weather
#
# How often to sweep (seconds). Each domain's own interval is enforced via
# watermarks — this is just how often the scheduler wakes to check.
# Default 900 = 15 minutes (matches the fastest domain: air/fire).
SWEEP_INTERVAL_SEC=900
#
# Whether the AI agent runs automatically after each ingest sweep
SCHEDULER_AGENT=true
#
# Max cells to analyse per city per agent sweep
SCHEDULER_TOP_N=10

# ── H3 Expert Agent — LLM provider ───────────────────────────────────────────
# Provider preset: anthropic | ollama | openai | groq | together | openrouter | lmstudio | custom
# Default: ollama (local, no API key needed — run: ollama pull llama3.2)
#
# To use Claude (recommended):
#   LLM_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-...   (or set LLM_API_KEY=sk-ant-...)
#   LLM_MODEL=claude-haiku-4-5   (fast+cheap) or claude-sonnet-4-5 (smarter)
LLM_PROVIDER=ollama

# Anthropic API key — required when LLM_PROVIDER=anthropic
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Base URL of the OpenAI-compatible endpoint (not used for anthropic provider)
# Ollama default:      http://localhost:11434/v1
# Groq:                https://api.groq.com/openai/v1
# Together:            https://api.together.xyz/v1
# OpenRouter:          https://openrouter.ai/api/v1
# LM Studio:           http://localhost:1234/v1
LLM_BASE_URL=http://localhost:11434/v1

# API key — use 'ollama' for local Ollama (key is ignored)
# For Anthropic, prefer ANTHROPIC_API_KEY above instead.
LLM_API_KEY=ollama

# Model name as the provider expects it
# Anthropic: claude-haiku-4-5, claude-sonnet-4-5, claude-opus-4-5
# Ollama tool-calling models: llama3.2, llama3.1, qwen2.5, mistral-nemo
# Groq:      llama-3.3-70b-versatile, mixtral-8x7b-32768
# OpenAI:    gpt-4o, gpt-4o-mini
# Together:  meta-llama/Llama-3.3-70B-Instruct-Turbo
# OpenRouter: google/gemini-flash-1.5, anthropic/claude-opus-4-5
LLM_MODEL=gpt-oss:20b-cloud

# Generation parameters
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=120

# ── Web search (optional — used by H3 Expert Agent to validate findings) ──────
# Provider: none | duckduckgo | tavily | brave | serpapi
# Default: none (search disabled — agent works without it)
#
# duckduckgo  No API key needed. pip install duckduckgo-search
# tavily      pip install tavily-python  |  key from tavily.com
# brave       No extra package (uses requests)  |  key from brave.com/search/api
# serpapi     pip install google-search-results  |  key from serpapi.com
WEB_SEARCH_PROVIDER=none
# WEB_SEARCH_API_KEY=your-key-here
