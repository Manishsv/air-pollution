# Optional: NASA FIRMS API key for fire events
FIRMS_API_KEY=

# Optional: OpenAQ v3 API key (recommended; v2 is retired and returns 410)
OPENAQ_API_KEY=

# ── AIR Climate Suite data sources ───────────────────────────────────────

# CPCB real-time AQI (data.gov.in) — enables real Indian station data for air quality
# Without this, air panel falls back to OpenMeteo (coarser grid, synthetic)
CPCB_API_KEY=

# Google Earth Engine project ID — enables MODIS LST (heat) + GPM IMERG (flood)
# Without this, heat and flood panels fall back to OpenMeteo
GEE_PROJECT=

# GEE service account credentials (required when interactive OAuth is blocked)
# Create a service account in Cloud Console → download JSON key → set both vars:
GEE_SERVICE_ACCOUNT=airclimate-gee@your-project.iam.gserviceaccount.com
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gee-key.json
