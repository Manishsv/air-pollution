# Optional: NASA FIRMS API key for fire events
FIRMS_API_KEY=

# Optional: OpenAQ v3 API key (recommended; v2 is retired and returns 410)
OPENAQ_API_KEY=

# ── AIR Climate Suite data sources ───────────────────────────────────────

# CPCB real-time AQI (data.gov.in) — enables real Indian station data for air quality
# Without this, air panel falls back to OpenMeteo (coarser grid, synthetic)
CPCB_API_KEY=

# Google Earth Engine project ID — enables MODIS LST (heat) + GPM IMERG (flood)
# Without this, heat and flood panels fall back to OpenMeteo
GEE_PROJECT=

# GEE service account credentials (required when interactive OAuth is blocked)
# Create a service account in Cloud Console → download JSON key → set both vars:
GEE_SERVICE_ACCOUNT=airclimate-gee@your-project.iam.gserviceaccount.com
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gee-key.json

# ── AIR Climate Suite notifications ──────────────────────────────────────────

# Backend: log (default) | smtp | digit3
NOTIFICATION_BACKEND=log

# Recipients — comma-separated email addresses (city-specific key overrides global)
ALERT_RECIPIENTS=officer@city.gov.in
ALERT_RECIPIENTS_BANGALORE=bangalore-officer@bbmp.gov.in

# SMTP backend (set NOTIFICATION_BACKEND=smtp to use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@airclimate.in

# DIGIT3 Notification backend (set NOTIFICATION_BACKEND=digit3 when DIGIT3 is deployed)
DIGIT3_NOTIFICATION_URL=http://digit3-host/notification/v1/send
DIGIT3_AUTH_TOKEN=

# ── AIR Climate Suite Decision Object transport ───────────────────────────────

# POST Decision Objects to AIRNet events endpoint (when AIRNet is deployed)
# Without this, decisions are appended to DECISION_LOG_PATH (local fallback)
AIRNET_EVENTS_URL=

# Local fallback log for Decision Objects (default: data/events/decisions.jsonl)
DECISION_LOG_PATH=data/events/decisions.jsonl
